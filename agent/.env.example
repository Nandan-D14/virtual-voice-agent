# E2B Desktop Sandbox
E2B_API_KEY=
REQUIRE_BYOK=false
BYOK_ENCRYPTION_KEY=
SHARED_ACCESS_CODE=
BETA_ENFORCE_BYOK=true
BETA_ADMIN_EMAILS=
BETA_GOOGLE_SHEET_ID=
BETA_GOOGLE_SHEET_NAME=beta_applications
SANDBOX_CREATE_RETRIES=3
SANDBOX_CREATE_RETRY_BACKOFF_SECONDS=2
SANDBOX_CREATE_RETRY_MAX_SECONDS=10

# Google / Gemini
GOOGLE_API_KEY=
GOOGLE_PROJECT_ID=
GOOGLE_CLOUD_REGION=us-central1

# Kilo / minimax (used for agent reasoning + tool calls)
KILO_API_KEY=
KILO_MODEL_ID=minimax/minimax-m2.5:free
KILO_GATEWAY_URL=https://api.kilo.ai/api/gateway

# Firebase Admin / Firestore
FIREBASE_PROJECT_ID=${FIREBASE_PROJECT_ID:?Set FIREBASE_PROJECT_ID}
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_AUTH_EMULATOR_HOST=
FIRESTORE_EMULATOR_HOST=

# Server
FRONTEND_URL=http://localhost:3000

# Session
SESSION_TIMEOUT_MINUTES=15
JWT_SECRET=dev-secret-change-in-production
